{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rewrites": [{ "source": "/(.*)", "destination": "/" }],
    "git": {
        "deploymentEnabled": {
            "gh-pages": false
        }
    },
    "headers": [
        {
            "source": "/(.*).wasm",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/wasm"
                }
            ]
        },
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "cache-control",
                    "value": "public,max-age=31536000,immutable"
                }
            ]
        }
    ]
}
