//# init --addresses test=0x0

//# publish
module test.external {
    import 0x2.object;

    struct Account has key {
        id: object.UID,
    }

    public uid(self: &Self.Account): &object.UID {
        let id: &object.UID;
        label l0:
        id = &move(self).Account::id;
        return move(id);
    }

}

//# set-address test object(1,0)

//# publish --dependencies test
module 0x0.m {
    import 0x2.account;
    import 0x2.authenticator_function;
    import 0x2.object;
    import test.external;

    t1(account: &external.Account): &authenticator_function.AuthenticatorFunctionRefV1<external.Account> {
        let a: &authenticator_function.AuthenticatorFunctionRefV1<external.Account>;
        let id: &object.UID;
        label l0:
        id = external.uid(move(account));
        a = account.borrow_auth_function_ref_v1<external.Account>(move(id));
        return move(a);
    }
}

