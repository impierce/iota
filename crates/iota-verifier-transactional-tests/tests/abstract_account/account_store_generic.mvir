//# publish
module 0x0.m {
    import 0x2.account;
    import 0x2.authenticator_function;

    t3<T0: key + store>(account: &mut T0, authenticator: authenticator_function.AuthenticatorFunctionRefV1<T0>): authenticator_function.AuthenticatorFunctionRefV1<T0> {
        let a: authenticator_function.AuthenticatorFunctionRefV1<T0>;
        label l0:
        a = account.rotate_auth_function_ref_v1<T0>(move(account), move(authenticator));
        return move(a);
    }
}
