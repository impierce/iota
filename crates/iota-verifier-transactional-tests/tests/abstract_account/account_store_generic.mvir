//# publish
module 0x0.m {
    import 0x2.account;
    import 0x2.authenticator_function;

    t1<T0: key + store>(account: T0, authenticator: authenticator_function.AuthenticatorFunctionRefV1<T0>) {
        label l0:
        account.create_account_v1<T0>(move(account), move(authenticator));
        return;
    }
}

//# publish
module 0x0.m {
    import 0x2.account;
    import 0x2.authenticator_function;

    t2<T0: key + store>(account: T0, authenticator: authenticator_function.AuthenticatorFunctionRefV1<T0>) {
        label l0:
