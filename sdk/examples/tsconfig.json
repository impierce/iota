{
    "compilerOptions": {
        "outDir": "dist/esm",
        "rootDir": "src",
        "module": "ES2022",
        "target": "ES2022",
        "moduleResolution": "bundler",
        "noEmit": false,
        "declaration": false,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src"],
    "exclude": ["dist", "node_modules"]
}
