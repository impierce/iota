{
	"name": "iota-monorepo",
	"private": true,
	"license": "Apache-2.0",
	"scripts": {
		"test": "turbo run test",
		"test:dev": "turbo run test -- --run",
		"icons": "pnpm --filter ./apps/ui-icons",
		"explorer-dev": "turbo --filter iota-explorer --filter apps-backend dev",
		"wallet-dev": "turbo --filter ./apps/wallet --filter apps-backend dev",
		"wallet-dashboard-dev": "turbo --filter ./apps/wallet-dashboard --filter apps-backend dev",
		"multisig": "turbo --filter ./dapps/multisig-toolkit",
		"evm-bridge": "turbo --filter ./apps/evm-bridge",
		"evm-bridge-dev": "turbo --filter ./apps/evm-bridge --filter apps-backend dev",
		"ui-kit": "turbo --filter ./apps/ui-kit",
		"explorer": "turbo --filter iota-explorer",
		"wallet": "turbo --filter ./apps/wallet",
		"wallet-dashboard": "turbo --filter ./apps/wallet-dashboard",
		"sdk-packages": "pnpm turbo run --filter=./sdk/* --filter=./apps/ui-kit --filter=./apps/ui-icons",
		"sdk": "turbo --filter ./sdk/typescript",
		"signers": "turbo --filter ./sdk/signers",
		"bcs": "turbo --filter ./sdk/bcs",
		"isc-sdk": "turbo --filter ./sdk/isc-sdk",
		"apps-backend": "turbo --filter apps-backend",
		"iota-docs": "turbo --filter iota-docs",
		"examples": "turbo --filter ./sdk/examples",
		"changeset-publish": "pnpm changeset publish",
		"changeset-version": "pnpm changeset version",
		"prepare": "husky",
		"codegen": "turbo run codegen"
	},
	"pnpm": {
		"overrides": {
			"path-to-regexp@<0.1.12": "^0.1.12",
			"image-size@<1.1.1": "^1.2.1",
			"multer@<2.1.1": "^2.1.1",
			"immutable@>=5.0.0 <5.1.5": "5.1.5",
			"svgo@>=3.0.0 <3.3.3": "3.3.3",
			"serialize-javascript": ">=7.0.3",
			"form-data@>=4.0.0 <4.0.4": "^4.0.4",
			"sha.js": "^2.4.12",
			"@mestamask/sdk@<0.33.0": "0.33.0",
			"@mestamask/sdk-communication-layer@<0.33.0": "0.33.0",
			"validator@<13.15.15": "13.15.15",
			"node-forge@1.3.1": "^1.3.3",
			"glob@>=10.2.0 <10.5.0": "10.5.0",
			"qs@<6.14.1": "6.14.1",
			"preact@>=10.28.0 <10.28.2": "10.28.2",
			"h3@<1.15.6": "1.15.8",
			"minimatch@>=3.0.0": "^3.1.5",
			"minimatch@>=5.0.0": "^5.1.9",
			"minimatch@>=9.0.0": "^9.0.9",
			"hono@<4.12.4": ">=4.12.4",
			"axios@<0.30.3": "^0.30.3",
			"socket.io-parser@<4.2.6": "4.2.6",
			"picomatch@<2.3.2": "^2.3.2",
			"picomatch@>=4.0.0 <4.0.4": "^4.0.4"
		}
	},
	"engines": {
		"node": ">=24",
		"pnpm": ">=10"
	},
	"manypkg": {
		"ignoredRules": [
			"INTERNAL_MISMATCH",
			"ROOT_HAS_DEV_DEPENDENCIES"
		]
	},
	"devDependencies": {
		"@changesets/cli": "^2.27.5",
		"@manypkg/cli": "^0.21.4",
		"@tanstack/eslint-plugin-query": "^5.35.6",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"concurrently": "^8.2.2",
		"eslint": "^8.45.0",
		"eslint-config-next": "14.2.3",
		"eslint-config-prettier": "^9.1.0",
		"eslint-import-resolver-typescript": "^3.6.1",
		"eslint-plugin-header": "^3.1.1",
		"eslint-plugin-import": "^2.29.1",
		"eslint-plugin-license-check": "link:linting/license-check",
		"eslint-plugin-prettier": "^5.1.3",
		"eslint-plugin-require-extensions": "^0.1.3",
		"eslint-plugin-tsdoc": "^0.2.17",
		"eslint-plugin-unused-imports": "^3.2.0",
		"graphql-config": "^5.0.3",
		"husky": "^9.0.11",
		"lint-staged": "^15.2.5",
		"prettier": "^3.3.1",
		"prettier-plugin-tailwindcss": "^0.4.1",
		"tsx": "^3.12.7",
		"turbo": "^2.8.0",
		"typescript": "^5.5.3",
		"typescript-eslint": "^7.12.0"
	},
	"dependencies": {
		"copy-text-to-clipboard": "^3.2.0"
	},
	"packageManager": "pnpm@10.30.0"
}
